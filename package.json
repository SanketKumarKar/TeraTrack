    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
