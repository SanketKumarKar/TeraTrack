    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
